msgstr "per un any"

msgid "for six months"
msgstr "durant sis mesos"

msgid "for one month"
msgstr "durant un mes"

msgid "for one week"
msgstr "durant una setmana"

msgid "for one day"
msgstr "per un dia"

msgid "for one hour"
msgstr "durant una hora"

msgid "after the last signature."
msgstr "després de l'última signatura."

msgid "The PDF will be stored encrypted on the server"
msgstr "El PDF s'emmagatzemarà encriptat al servidor"

